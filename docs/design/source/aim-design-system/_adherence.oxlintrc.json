{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/_util/**",
              "components/buttons/**",
              "components/feedback/**",
              "components/forms/**",
              "components/learning/**",
              "components/navigation/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|IBM Plex Sans Arabic))/i]",
        "message": "Font not provided by the design system. Available: Inter, IBM Plex Sans Arabic."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIFeedbackBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|tone|typing|children|key|ref|className|style|children)$/]",
        "message": "<AIFeedbackBubble> doesn't accept that prop. Declared props: name, tone, typing, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIFeedbackBubble'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|praise|correction)$/]",
        "message": "<AIFeedbackBubble> tone must be one of 'neutral' | 'praise' | 'correction'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|dismissible|onDismiss|action|children|key|ref|className|style|children)$/]",
        "message": "<AlertBanner> doesn't accept that prop. Declared props: tone, title, dismissible, onDismiss, action, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertBanner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|success|warning|error)$/]",
        "message": "<AlertBanner> tone must be one of 'info' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnswerOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|optionKey|children|key|ref|className|style|children)$/]",
        "message": "<AnswerOption> doesn't accept that prop. Declared props: state, optionKey, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnswerOption'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:default|selected|correct|incorrect|reveal)$/]",
        "message": "<AnswerOption> state must be one of 'default' | 'selected' | 'correct' | 'incorrect' | 'reveal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|pill|dot|icon|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, variant, pill, dot, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|secondary|accent|success|warning|error|info|neutral)$/]",
        "message": "<Badge> tone must be one of 'primary' | 'secondary' | 'accent' | 'success' | 'warning' | 'error' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|outline)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid' | 'outline'."
