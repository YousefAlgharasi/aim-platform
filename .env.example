APP_ENV=development
DATABASE_URL=sqlite:///./aim_dev.db

# Cloud/Supabase PostgreSQL. Prefer the Session pooler for a long-running
# FastAPI backend on IPv4-only hosts, or the direct connection on IPv6 hosts.
# SUPABASE_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://example.supabase.co
SUPABASE_AUTH_REQUIRED=true
SUPABASE_JWT_AUDIENCE=authenticated
# Optional legacy/shared-secret JWT verification. Prefer Supabase JWKS signing keys
# for new projects; never expose this value to React/Vite/Next public env vars.
# SUPABASE_JWT_SECRET=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=1800

API_TITLE=AIM Backend
API_DESCRIPTION=Adaptive Intelligence Module API
API_VERSION=0.1.0

# React cloud build variables. These are public browser values only.
REACT_APP_API_BASE_URL=https://aim-api.example.com
REACT_APP_SUPABASE_URL=https://example.supabase.co
REACT_APP_SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-publishable-key

