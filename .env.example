# =============================================================================
# AIM Platform — Phase 1 Environment Variables
# =============================================================================
# Placeholders only. No real credentials are committed to this repository.
# Copy the relevant section to the corresponding service .env file.
# All .env files are excluded from git via .gitignore.
# =============================================================================


# =============================================================================
# services/backend-api/  — NestJS + TypeScript
# =============================================================================

# Application
NODE_ENV=development
PORT=3000

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<placeholder>
SUPABASE_SERVICE_ROLE_KEY=<placeholder>
SUPABASE_JWT_SECRET=<placeholder>
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<host>:5432/postgres

# AIM Engine internal URL (backend-to-backend only)
AIM_ENGINE_URL=http://localhost:8000

# AI Teacher Gateway — backend-only, never exposed to any client
AI_PROVIDER_API_KEY=<placeholder>
AI_PROVIDER_MODEL=<placeholder>
# Optional — defaults to OpenAI's endpoint. Set to any OpenAI-compatible
# provider's chat-completions URL (e.g. https://api.groq.com/openai/v1/chat/completions)
# to use that provider instead, with no code change.
# AI_PROVIDER_BASE_URL=https://api.openai.com/v1/chat/completions

# Voice Mode STT Gateway — backend-only, never exposed to any client
STT_PROVIDER_API_KEY=<placeholder>
STT_PROVIDER_MODEL=<placeholder>

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Placement retake cooldown (hours, default: 24)
# PLACEMENT_RETAKE_COOLDOWN_HOURS=24


# =============================================================================
# services/aim-engine/  — Python
# =============================================================================

# Application
APP_ENV=development
AIM_ENGINE_PORT=8000

# Supabase (service-role for backend read access)
# AIM_SUPABASE_URL=https://<project-ref>.supabase.co
# AIM_SUPABASE_SERVICE_ROLE_KEY=<placeholder>

# AI Provider (only if AIM Engine calls providers directly)
# AIM_AI_PROVIDER_API_KEY=<placeholder>


# =============================================================================
# apps/admin-dashboard/  — Internal Admin Dashboard
# =============================================================================
# NEXT_PUBLIC_ prefix = bundled into browser client — never use for secrets.

NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<placeholder>


# =============================================================================
# apps/mobile/  — Flutter Mobile
# =============================================================================
# Flutter does not use a .env file. Pass build-time constants via --dart-define
# or a local lib/config/ file excluded from git.
#
# Example flutter run flags:
#   --dart-define=AIM_ENV=local
#   --dart-define=BACKEND_API_BASE_URL=http://localhost:3000
#   --dart-define=SUPABASE_URL=https://<project-ref>.supabase.co
#   --dart-define=SUPABASE_ANON_KEY=<anon-key>
#
# SUPABASE_URL and SUPABASE_ANON_KEY are public client-safe values.
# Never pass SUPABASE_SERVICE_ROLE_KEY, SUPABASE_JWT_SECRET,
# or AI_PROVIDER_API_KEY to any Flutter build.
