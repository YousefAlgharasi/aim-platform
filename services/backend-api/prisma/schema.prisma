generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  supabaseAuthUid String   @unique @map("supabase_auth_uid") @db.Uuid

  email           String?
  phone           String?

  userType        String   @default("student") @map("user_type")
  status          String   @default("active")

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  studentProfile  StudentProfile?
  aiChatSessions  AiChatSession[]
  voiceSessions   VoiceSession[]

  @@index([supabaseAuthUid])
  @@index([email])
  @@index([status])
  @@index([userType])
  @@map("users")
}

model StudentProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  profileType       String   @default("student_profile") @map("profile_type")

  displayName       String?  @map("display_name")
  avatarUrl         String?  @map("avatar_url")
  preferredLanguage String?  @map("preferred_language")
  timezone          String?

  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  levelStates       StudentLevelState[]
  focusDirectives   AiFocusDirective[]

  @@index([userId])
  @@index([profileType])
  @@map("student_profiles")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  permissions RolePermission[]

  @@index([key])
  @@index([isSystem])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  scope       String
  description String?

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  roles        RolePermission[]

  @@index([key])
  @@index([scope])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AiChatSession {
  id          String              @id @default(uuid()) @db.Uuid
  studentId   String              @map("student_id") @db.Uuid

  contextRef  String              @map("context_ref")
  status      String              @default("active")

  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  student     User                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  messages    AiChatMessage[]
  snapshots   AiContextSnapshot[]

  @@index([studentId])
  @@index([studentId, status])
  @@index([studentId, createdAt(sort: Desc)])
  @@index([status])
  @@map("ai_chat_sessions")
}

model VoiceSession {
  id          String   @id @default(uuid()) @db.Uuid
  studentId   String   @map("student_id") @db.Uuid

  contextRef  String   @map("context_ref")
  status      String   @default("active")

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  messages    VoiceMessage[]

  @@index([studentId])
  @@index([studentId, status])
  @@index([studentId, createdAt(sort: Desc)])
  @@index([status])
  @@map("voice_sessions")
}

model VoiceMessage {
  id          String       @id @default(uuid()) @db.Uuid
  sessionId   String       @map("session_id") @db.Uuid
  studentId   String       @map("student_id") @db.Uuid

  transcript  String?
  reply       String?
  audioRef    String?      @map("audio_ref")

  status      String       @default("pending")

  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  session     VoiceSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  audioAsset  VoiceAudioAsset?
  providerLogs VoiceProviderLog[]

  @@index([sessionId, createdAt(sort: Asc)])
  @@index([studentId, createdAt(sort: Desc)])
  @@index([sessionId, status])
  @@map("voice_messages")
}

model VoiceProviderLog {
  id            String       @id @default(uuid()) @db.Uuid
  messageId     String       @map("message_id") @db.Uuid

  providerType  String       @map("provider_type")
  provider      String
  model         String

  status        String
  errorCategory String?      @map("error_category")

  latencyMs     Int?         @map("latency_ms")

  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  message       VoiceMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([providerType])
  @@index([status])
  @@index([messageId, createdAt(sort: Desc)])
  @@map("voice_provider_logs")
}

model VoiceAudioAsset {
  id          String       @id @default(uuid()) @db.Uuid
  messageId   String       @unique @map("message_id") @db.Uuid
  studentId   String       @map("student_id") @db.Uuid

  storageKey  String       @map("storage_key")
  contentType String       @map("content_type")
  durationMs  Int?         @map("duration_ms")

  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  message     VoiceMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt(sort: Desc)])
  @@map("voice_audio_assets")
}

model AiChatMessage {
  id          String             @id @default(uuid()) @db.Uuid
  sessionId   String             @map("session_id") @db.Uuid
  studentId   String             @map("student_id") @db.Uuid

  role        String
  text        String

  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  session     AiChatSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  snapshot    AiContextSnapshot?

  @@index([sessionId, createdAt(sort: Asc)])
  @@index([studentId, createdAt(sort: Desc)])
  @@index([sessionId, role])
  @@map("ai_chat_messages")
}

model AiContextSnapshot {
  id           String        @id @default(uuid()) @db.Uuid
  sessionId    String        @map("session_id") @db.Uuid
  messageId    String        @unique @map("message_id") @db.Uuid
  studentId    String        @map("student_id") @db.Uuid

  contextData  Json          @default("{}") @map("context_data")

  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  session      AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message      AiChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([studentId, createdAt(sort: Desc)])
  @@map("ai_context_snapshots")
}

model Course {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  slug        String?  @unique
  description String?

  sortOrder   Int      @default(0) @map("sort_order")
  status      String   @default("draft")

  trackSlug   String   @default("english") @map("track_slug")
  cefrCode    String?  @map("cefr_code")
  cefrRank    Int?     @map("cefr_rank") @db.SmallInt

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // (trackSlug, cefrRank) is enforced unique at the DB level by a partial
  // index (WHERE cefr_rank IS NOT NULL) — see migration
  // 20260703150000_add_course_cefr_rank. Prisma's schema language has no
  // partial-index syntax without the extendedIndexes preview feature, so
  // it isn't declared here.
  @@index([status])
  @@index([sortOrder])
  @@map("courses")
}

model StudentLevelState {
  id                  String   @id @default(uuid()) @db.Uuid
  studentId           String   @map("student_id") @db.Uuid
  trackSlug           String   @default("english") @map("track_slug")

  currentCefrRank     Int      @map("current_cefr_rank") @db.SmallInt
  maxUnlockedCefrRank Int      @map("max_unlocked_cefr_rank") @db.SmallInt
  source              String

  lastComputedAt      DateTime @default(now()) @map("last_computed_at") @db.Timestamptz(6)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  student             StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, trackSlug])
  @@index([studentId])
  @@map("student_level_state")
}

model AiFocusDirective {
  id            String   @id @default(uuid()) @db.Uuid
  studentId     String   @map("student_id") @db.Uuid
  skillId       String   @map("skill_id")

  directiveText String   @map("directive_text")
  source        String
  sourceId      String?  @map("source_id") @db.Uuid

  generatedAt   DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, active])
  @@map("ai_focus_directives")
}
