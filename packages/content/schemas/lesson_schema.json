{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aim:content:lesson_schema:v1",
  "title": "AIM Lesson Schema",
  "description": "Validates a complete lesson JSON file for the AIM A1 pilot curriculum.",
  "type": "object",
  "required": [
    "lesson_id",
    "title_en",
    "title_ar",
    "week",
    "difficulty",
    "prerequisites",
    "skills_covered",
    "learning_objectives",
    "questions"
  ],
  "properties": {
    "lesson_id": {
      "type": "string",
      "pattern": "^L[0-9]{2}$",
      "description": "Unique lesson identifier. Format: L<NN>."
    },
    "task_id": {
      "type": "string",
      "description": "Traceability reference to the Notion task that created this lesson."
    },
    "title_en": {
      "type": "string",
      "minLength": 3,
      "description": "Lesson title in English."
    },
    "title_ar": {
      "type": "string",
      "minLength": 3,
      "description": "Lesson title in Arabic."
    },
    "week": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2,
      "description": "Pilot week this lesson belongs to (1 or 2)."
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Lesson difficulty level. Used by the difficulty adapter."
    },
    "sprint": {
      "type": "string",
      "description": "Development sprint reference."
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^SK-[A-Z][0-9]{2}$"
      },
      "description": "Skill IDs that must be mastered before starting this lesson."
    },
    "skills_covered": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^SK-[A-Z][0-9]{2}$"
      },
      "minItems": 1,
      "description": "Skill IDs taught or practiced in this lesson."
    },
    "learning_objectives": {
      "type": "array",
      "items": {"type": "string", "minLength": 5},
      "minItems": 1,
      "description": "Measurable learning objectives for this lesson."
    },
    "questions": {
      "type": "array",
      "items": {"$ref": "question_schema.json"},
      "minItems": 3,
      "description": "Questions in this lesson. Each must pass the question schema."
    }
  },
  "additionalProperties": false
}
